{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "One Paper Protocol Core Specification",
  "type": "object",
  "properties": {
    "protocol": { "type": "string", "const": "OPP/1.0" },
    "id": { "type": "string" },
    "metadata": {
      "type": "object",
      "required": ["timestamp", "issuer", "proof"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "issuer": { "type": "string" },
        "proof": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "url": { "type": "string" }
          }
        }
      }
    },
    "body": {
      "type": "object",
      "required": ["nodes"],
      "properties": {
        "title": { "type": "string" },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "label", "value"],
            "properties": {
              "type": { "enum": ["field", "status", "image", "signature"] },
              "label": { "type": "string" },
              "value": { "type": "string" },
              "style": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
